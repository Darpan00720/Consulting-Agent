# ── Groq API key (free tier — get one at console.groq.com, no card needed) ───
# Users visit the hosted link and run cases for free — no key required on their end.
GROQ_API_KEY=gsk_...

# ── Model (optional) ──────────────────────────────────────────────────────────
# Llama 3.3 70B is the default. All listed models are on Groq's free tier.
# Options: llama-3.3-70b-versatile | llama-3.1-8b-instant | moonshotai/kimi-k2-instruct
STRATAGENT_MODEL=llama-3.3-70b-versatile

# ── Daily free-tier quota per anonymous browser identity ──────────────────────
# Set to 0 to disable rate-limiting (open use).
STRATAGENT_DAILY_QUOTA=5

# ── Frontend → Backend URL ────────────────────────────────────────────────────
# When deploying, set this to the public URL of the backend so the browser can reach it.
# Example: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000
