{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dashboard-backend",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "app.main:app", "--port", "8000"],
      "cwd": "apps/dashboard/backend",
      "comment": "Provider keys come from apps/dashboard/.env (gitignored) — NEVER hardcode a key here; this file is tracked.",
      "port": 8000
    },
    {
      "name": "dashboard-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "apps/dashboard/frontend",
      "port": 3000
    }
  ]
}
