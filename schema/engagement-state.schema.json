{
  "$defs": {
    "EngagementMetadata": {
      "additionalProperties": false,
      "description": "ADR-002 \u00a71 \u2014 Engagement Metadata.",
      "properties": {
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "created_by": {
          "default": "human",
          "enum": [
            "human",
            "system"
          ],
          "title": "Created By",
          "type": "string"
        },
        "engagement_id": {
          "title": "Engagement Id",
          "type": "string"
        },
        "schema_version": {
          "default": 1,
          "title": "Schema Version",
          "type": "integer"
        },
        "slug": {
          "title": "Slug",
          "type": "string"
        },
        "state_version": {
          "default": 0,
          "title": "State Version",
          "type": "integer"
        },
        "tenant_id": {
          "title": "Tenant Id",
          "type": "string"
        },
        "updated_at": {
          "format": "date-time",
          "title": "Updated At",
          "type": "string"
        }
      },
      "required": [
        "engagement_id",
        "tenant_id",
        "slug"
      ],
      "title": "EngagementMetadata",
      "type": "object"
    },
    "LifecycleStatus": {
      "description": "The engagement state-machine positions defined in ADR-002 \u00a72.",
      "enum": [
        "intake",
        "classifying",
        "gap_analysis",
        "planning",
        "framing",
        "issue_tree",
        "knowledge",
        "analysis",
        "evidence_validation",
        "review",
        "challenge",
        "reporting",
        "completed",
        "failed",
        "aborted"
      ],
      "title": "LifecycleStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Root Engagement State (M0 foundational slice).\n\nExtended in M1 with the remaining ADR-002 sections (problem definition,\nledgers, analysis sections, gates, recommendation, audit trail, ...).",
  "properties": {
    "metadata": {
      "$ref": "#/$defs/EngagementMetadata"
    },
    "status": {
      "$ref": "#/$defs/LifecycleStatus",
      "default": "intake"
    }
  },
  "required": [
    "metadata"
  ],
  "title": "EngagementState",
  "type": "object"
}
